node_modules/
.pnpm-store/
.yarn/
.yarn-integrity
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo

# Logs npm/yarn/pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Builds frontend
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist
.svelte-kit/

