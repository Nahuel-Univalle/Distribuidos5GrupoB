# ============================================================================
services/pdf-service/output/
services/pdf-service/temp/
*.pdf
!docs/**/*.pdf
!docs/img/samples/*.pdf
!REGLAMENTO*.pdf

# === Claude Code (workspace local) ===
.claude/

# ============================================================================
# Logs y temporales
# ============================================================================
logs/
*.log
*.log.*
*.tmp
*.bak
*.old
*.orig
.tmp/

# ============================================================================
# Backups y archivos comprimidos accidentales
# ============================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
!docs/**/*.zip

# ============================================================================
# Reportes de testing
# ============================================================================
test-results/
playwright-report/
playwright/.cache/

# ============================================================================
