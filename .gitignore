# ============================================================================
data/generated/
data/output/
lora-data/**
!lora-data/.gitkeep
*.csv.bak
*.csv.tmp
*.sqlite
*.sqlite3
*.db

# === Cassandra data persistente ===
infra/cassandra/data/
infra/cassandra/logs/
infra/cassandra/commitlog/

# === RabbitMQ data ===
infra/rabbitmq/data/

# === Redis data ===
infra/redis/data/
dump.rdb

# ============================================================================
