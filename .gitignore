.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
*.swp
*.swo
*~

# === Editores e IDEs ===
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
*.iml
.project
.classpath
.settings/

# ============================================================================
# Variables de entorno y secretos (NUNCA SUBIR)
# ============================================================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example
*.pem
*.key
*.cert
*.crt
secrets/
credentials/
private/

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
