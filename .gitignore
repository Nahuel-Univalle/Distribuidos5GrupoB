.installed.cfg
*.egg
MANIFEST

# Entornos virtuales Python
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
.python-version
pyvenv.cfg

# Testing y coverage Python
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
