# ============================================================================
# SEMAPA - Variables de entorno (PLANTILLA)
# Copia este archivo a .env y reemplaza los valores marcados con CHANGE_ME.
# NUNCA subas .env al repositorio (está en .gitignore).
# ============================================================================

# ===== Cassandra =====
CASSANDRA_HOSTS=cassandra-1,cassandra-2
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=semapa
CASSANDRA_USER=cassandra
CASSANDRA_PASSWORD=cassandra
CASSANDRA_DC=datacenter1
CASSANDRA_REPLICATION_FACTOR=2

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== RabbitMQ =====
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=semapa
RABBITMQ_PASSWORD=semapa
RABBITMQ_MGMT_PORT=15672
RABBITMQ_VHOST=/

# ===== JWT =====
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=720

# ===== EMAIL ==================================================================
# Proveedor: "mailtrap" (Mailtrap Sending) o "mailhog" (dev local sin auth)
EMAIL_PROVIDER=mailtrap
SMTP_FROM=no-reply@demomailtrap.co
SMTP_FROM_NAME=SEMAPA

# --- Mailtrap (https://mailtrap.io) ---
MAILTRAP_TOKEN=CHANGE_ME_MAILTRAP_API_TOKEN
MAILTRAP_INBOX_ID=

# --- Mailhog (fallback dev) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# ===== TWILIO (SMS + WhatsApp Sandbox) =======================================
TWILIO_ACCOUNT_SID=CHANGE_ME_AC_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_AUTH_TOKEN
# SMS:
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SMS_FROM=+18777804236
# WhatsApp Sandbox (los destinatarios deben enviar primero "join glass-fifty" al +1 415 523 8886):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TEMPLATE_SID=HXb5b62575e6e4ff6129ad7c8efe1f983e

# Proveedores (twilio | mock)
SMS_PROVIDER=twilio
WHATSAPP_PROVIDER=twilio

# ===== API ===================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_LOG_LEVEL=INFO
API_CORS_ORIGINS=http://localhost,http://localhost:5173

# ===== Frontend Web ==========================================================
VITE_API_URL=http://localhost/api/v1
VITE_APP_NAME=SEMAPA

# ===== App Móvil =============================================================
EXPO_PUBLIC_API_URL=http://10.0.2.2/api/v1

# ===== Cotización USD (apilayer / exchangerate.host) =========================
# La API requiere apikey desde 2024. Endpoint:
#   https://api.exchangerate.host/live?source=USD&currencies=BOB
USD_API_URL=https://api.exchangerate.host/live?source=USD&currencies=BOB
USD_API_KEY=CHANGE_ME_EXCHANGERATE_API_KEY
USD_CACHE_TTL=900
USD_FALLBACK_RATE=6.96

# ===== Simulador LoRaWAN =====================================================
SIMULATOR_OUTPUT_DIR=/lora-data
SIMULATOR_BURST_SIZE=120
SIMULATOR_ERROR_RATE=0.005
SIMULATOR_DUPLICATE_RATE=0.0007

# ===== Ingestor ==============================================================
INGESTOR_WATCH_DIR=/lora-data
INGESTOR_BATCH_SIZE=30
INGESTOR_CONCURRENCY=100
INGESTOR_DEDUP_TTL=86400

# ===== Seeder ================================================================
SEEDER_PERSONAS_NATURALES=80000
SEEDER_PERSONAS_JURIDICAS=5000
SEEDER_INFRAESTRUCTURAS=100000
SEEDER_MEDIDORES=120000
SEEDER_FECHA_INICIO_LECTURAS=2025-04-01
SEEDER_CONCURRENCY=100
SEEDER_BATCH_SIZE=30

# ===== Observabilidad ========================================================
LOG_FORMAT=json
LOG_LEVEL=INFO
